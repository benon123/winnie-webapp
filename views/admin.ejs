<!DOCTYPE html>
<html>
<head>
<title>Admin Dashboard</title>

<style>
body {
  font-family: Arial;
  padding: 40px;
}

table{
  width:100%;
  border-collapse:collapse;
  box-shadow:0 4px 10px rgba(0,0,0,0.1);
}

th {
  background-color:#0d133d;
  color:white;
  text-align:center;
  padding:15px;
}

td {
  border:1px solid #ddd;
  padding:10px;
}

tr:nth-child(even){
  background-color:#f2f2f2;
}

button{
  padding:6px 10px;
  border:none;
  cursor:pointer;
}

.edit-btn{
  background-color:#0d133d;
  color:white;
}

.delete-btn{
  background-color:#dc3545;
  color:white;
}
</style>
</head>

<body>

<h1>Saved Contacts</h1>

<% if (contacts.length === 0) { %>
  <p>No contacts found.</p>
<% } else { %>

<a href="/" style="text-decoration:none;">
  <button style="background:#0d133d;color:white;padding:8px 14px;margin-bottom:15px;">
    Back to Website
  </button>
</a>

<table>
<tr>
  <th>Name</th>
  <th>Email</th>
  <th>Message</th>
  <th>Actions</th>
</tr>

<% contacts.forEach(contact => { %>
<tr>
  <td><%= contact.name %></td>
  <td><%= contact.email %></td>
  <td><%= contact.message %></td>

  <td>
    <!-- FIXED: _id → id -->
    <a href="/edit/<%= contact.id %>">
      <button class="edit-btn">Edit</button>
    </a>

    <form action="/delete/<%= contact.id %>" method="POST" style="display:inline;">
      <button class="delete-btn">Delete</button>
    </form>
  </td>
</tr>
<% }) %>

</table>

<% } %>

</body>
</html>